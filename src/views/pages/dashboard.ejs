<%- include("../partials/head") %>
<%- include("../partials/navbar") %>

<main class="dashboard-page">
  <%- include("../partials/flash") %>

  <section class="dashboard-header">
    <div>
      <span class="eyebrow">Welcome back</span>
      <h1><%= currentUser.name %>'s Dashboard</h1>
      <p>Upload or capture a waste image, request pickup, and earn rewards for completed waste collections.</p>
    </div>
    <div class="tip-card">
      <div class="model-card-header">
        <div>
          <h2>Your Rewards</h2>
          <p class="panel-subtitle">You earn points when your waste pickup is completed.</p>
        </div>
        <span class="status-badge reward-badge"><%= rewardSummary.points %> pts</span>
      </div>
      <div class="model-card-grid">
        <div class="model-card-item">
          <span>Total Reward Points</span>
          <strong id="rewardPointsTotal"><%= rewardSummary.points %></strong>
        </div>
        <div class="model-card-item">
          <span>Rewarded Pickups</span>
          <strong id="rewardedPickupTotal"><%= rewardSummary.rewardedPickups %></strong>
        </div>
      </div>
      <p class="tip-copy">
        Reward points are added after the admin marks your pickup as completed.
      </p>
    </div>
  </section>

  <section class="dashboard-grid">
    <article class="panel">
      <h2>Waste Detection</h2>
      <p class="panel-subtitle">Use file upload or your device camera.</p>

      <form id="detectionForm" class="detection-form">
        <label>
          Upload Image
          <input type="file" id="wasteImage" name="wasteImage" accept="image/*" required />
        </label>

        <div class="camera-actions">
          <button type="button" id="startCameraBtn" class="button button-secondary">
            Capture With Camera
          </button>
          <button type="button" id="takeSnapshotBtn" class="ghost-button" disabled>
            Take Snapshot
          </button>
        </div>

        <video id="cameraFeed" autoplay playsinline class="camera-feed hidden"></video>
        <canvas id="snapshotCanvas" class="hidden"></canvas>
        <img id="previewImage" class="preview-image hidden" alt="Selected waste preview" />

        <button type="submit" class="button" id="analyzeBtn">Analyze Waste</button>
        <p id="modelStatus" class="status-text">Loading custom waste model...</p>
      </form>
    </article>

    <article class="panel result-panel">
      <h2>Detection Result</h2>
      <div id="resultCard" class="result-card empty">
        <p>Upload or capture an image to see the predicted waste category.</p>
      </div>
    </article>
  </section>

  <section class="dashboard-grid dashboard-grid-alt">
    <article class="panel">
      <div class="section-heading">
        <div>
          <h2>Your Waste Statistics</h2>
          <p class="panel-subtitle">Track which waste categories you detect most often.</p>
        </div>
        <div class="stat-pill" id="totalDetectionsPill">0 total scans</div>
      </div>
      <div class="chart-grid">
        <div class="chart-card">
          <canvas id="wasteBreakdownChart"></canvas>
        </div>
        <div class="chart-card">
          <canvas id="wasteTrendChart"></canvas>
        </div>
      </div>
    </article>

    <article class="panel finder-panel">
      <div class="finder-top">
        <div>
          <h2>Find Center</h2>
          <p class="panel-subtitle">Search or view the center map.</p>
        </div>
        <span class="status-badge finder-active-badge">Active Center</span>
      </div>

      <div class="finder-active-card">
        <span class="finder-active-icon" aria-hidden="true">⌖</span>
        <div>
          <strong>Kuril&ndash;Khilkhet, Dhaka</strong>
          <p>Available for pickup and drop-off.</p>
        </div>
      </div>

      <form id="locationForm" class="finder-search">
        <div class="finder-search-field">
          <label for="locationInput">Area</label>
          <div class="finder-input-wrap">
            <span aria-hidden="true">⌕</span>
            <input
              type="text"
              id="locationInput"
              placeholder="Example: Kuril or Khilkhet"
              required
            />
          </div>
        </div>
        <div class="finder-actions">
          <button type="submit" class="button finder-primary-btn">
            <span aria-hidden="true">⌕</span>
            Search Map
          </button>
          <button type="button" id="showAllCentersBtn" class="button-secondary finder-secondary-btn">
            <span aria-hidden="true">▣</span>
            See All Centers
          </button>
        </div>
      </form>

      <button type="button" id="finderPreviewBtn" class="finder-preview" aria-label="Open all center locations map">
        <span class="finder-preview-grid"></span>
        <span class="finder-preview-pin"></span>
        <span class="finder-preview-label">Map Preview</span>
      </button>

      <div class="finder-status-shell">
        <p id="mapStatus" class="status-text finder-status">
          Search Kuril or Khilkhet to show the center.
        </p>
      </div>

      <div id="finderResults" class="finder-results hidden">
        <div class="finder-map-layout">
          <div class="finder-map-wrap">
            <div id="recyclingMap" class="map-box"></div>
          </div>
          <aside class="finder-side-panel">
            <div class="finder-side-head">
              <span class="eyebrow">Available Centers</span>
              <strong id="centerCountLabel">0</strong>
            </div>
            <div id="recyclingList" class="recycling-list"></div>
          </aside>
        </div>
      </div>
    </article>
  </section>

  <section class="panel">
    <div class="section-heading">
      <div>
        <h2>Request Waste Pickup</h2>
        <p class="panel-subtitle">Share your waste and address so the admin can arrange pickup and reward you after completion.</p>
      </div>
    </div>
    <form id="pickupRequestForm" class="pickup-form">
      <div class="pickup-grid">
        <label>
          Waste Type
          <input type="text" id="pickupWasteType" placeholder="Example: Plastic bottles" required />
        </label>
        <label>
          Approx. Weight
          <select id="pickupWeight" class="role-select" required>
            <option value="">Select weight</option>
            <option value="0.5">0.5 kg</option>
            <option value="1">1 kg</option>
            <option value="2">2 kg</option>
            <option value="5">5 kg</option>
            <option value="10">10 kg</option>
            <option value="15">15+ kg</option>
          </select>
        </label>
      </div>
      <div class="pickup-grid">
        <label>
          Upload Waste Image
          <input type="file" id="pickupImage" accept="image/*" />
        </label>
        <label>
          Use Previous Detection
          <select id="previousDetectionSelect" class="role-select">
            <option value="">Choose from history</option>
            <% history.forEach((item) => { %>
              <option
                value="<%= item._id %>"
                data-waste-type="<%= item.wasteType %>"
                data-image-path="<%= item.imagePath %>"
              >
                <%= item.wasteType %> - <%= new Date(item.createdAt).toLocaleString() %>
              </option>
            <% }) %>
          </select>
        </label>
      </div>
      <div id="pickupDetectedItemsPreview" class="detected-items-preview hidden"></div>
      <div class="pickup-grid">
        <label>
          Contact Phone
          <input type="text" id="pickupPhone" placeholder="Example: 01XXXXXXXXX" required />
        </label>
        <label>
          Area / Location Name
          <input type="text" id="pickupArea" value="Kuril, Dhaka" required />
        </label>
      </div>
      <label>
        Full Address
        <input type="text" id="pickupAddress" placeholder="House, road, landmark" required />
      </label>
      <div class="pickup-grid">
        <label>
          Latitude
          <input type="text" id="pickupLatitude" placeholder="Optional" />
        </label>
        <label>
          Longitude
          <input type="text" id="pickupLongitude" placeholder="Optional" />
        </label>
      </div>
      <label>
        Notes
        <input type="text" id="pickupNotes" placeholder="Optional note for pickup team" />
      </label>
      <button type="submit" class="button">Submit Pickup Request</button>
      <p id="pickupStatus" class="status-text">Submit your location to request pickup. Rewards appear after pickup is completed.</p>
    </form>

    <div class="table-wrapper">
      <table class="history-table">
        <thead>
          <tr>
            <th>Waste Type</th>
            <th>Image</th>
            <th>Weight</th>
            <th>Items</th>
            <th>Area</th>
            <th>Phone</th>
            <th>Status</th>
            <th>Reward</th>
            <th>Assigned To</th>
            <th>Date & Time</th>
          </tr>
        </thead>
        <tbody id="pickupHistoryBody">
          <% if (pickupRequests.length === 0) { %>
            <tr>
              <td colspan="10">No pickup requests yet.</td>
            </tr>
          <% } %>
          <% pickupRequests.forEach((item) => { %>
            <tr>
              <td><%= item.wasteType %></td>
              <td>
                <% if (item.imagePath) { %>
                  <img src="<%= item.imagePath %>" alt="<%= item.wasteType %>" class="history-thumb" />
                <% } else { %>
                  No image
                <% } %>
              </td>
              <td><%= item.approximateWeightKg || "N/A" %> kg</td>
              <td>
                <% (item.detectedItems || []).forEach((detectedItem) => { %>
                  <span class="mini-badge"><%= detectedItem.wasteType %> x<%= detectedItem.quantity %></span>
                <% }) %>
              </td>
              <td><%= item.areaName %></td>
              <td><%= item.contactPhone %></td>
              <td><%= item.status %></td>
              <td><%= item.rewardStatus === "earned" ? `${item.rewardPoints} pts` : "Pending" %></td>
              <td><%= item.assignedTo || "Not assigned" %></td>
              <td><%= new Date(item.createdAt).toLocaleString() %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="panel">
    <div class="history-header">
      <div>
        <h2>Detection History</h2>
        <p>Each analysis is stored with the image, waste type, and timestamp.</p>
      </div>
    </div>

    <div class="table-wrapper">
      <table class="history-table">
        <thead>
          <tr>
            <th>Image</th>
            <th>Waste Type</th>
            <th>Model Version</th>
            <th>Confidence</th>
            <th>Suggestion</th>
            <th>Date & Time</th>
          </tr>
        </thead>
        <tbody id="historyBody">
          <% if (history.length === 0) { %>
            <tr>
              <td colspan="6">No detections yet.</td>
            </tr>
          <% } %>
          <% history.forEach((item, index) => { %>
            <tr class="<%= index >= 3 ? 'hidden' : '' %>">
              <td><img src="<%= item.imagePath %>" alt="<%= item.wasteType %>" class="history-thumb" /></td>
              <td><%= item.wasteType %></td>
              <td><%= item.modelVersion || "1.0.0" %></td>
              <td><%= item.confidence ? `${(item.confidence * 100).toFixed(1)}%` : "N/A" %></td>
              <td><%= item.suggestion %></td>
              <td><%= new Date(item.createdAt).toLocaleString() %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% if (history.length > 0) { %>
      <div class="table-more-footer">
        <button type="button" id="openDetectionHistoryModalBtn" class="ghost-button">
          See More History
        </button>
      </div>
    <% } %>
  </section>
</main>

<div id="detectionHistoryModal" class="admin-list-modal hidden" aria-hidden="true">
  <div class="admin-list-modal-backdrop" data-close-history-modal></div>
  <section class="admin-list-modal-card admin-list-modal-card-wide" role="dialog" aria-modal="true" aria-labelledby="detectionHistoryModalTitle">
    <div class="admin-list-modal-header">
      <div>
        <h2 id="detectionHistoryModalTitle">Detection History</h2>
        <p class="panel-subtitle">Search, filter, and select one or multiple detections for pickup request.</p>
      </div>
      <button type="button" class="modal-close-button" data-close-history-modal aria-label="Close detection history popup">&times;</button>
    </div>
    <div class="admin-list-toolbar">
      <input type="search" id="historyModalSearch" placeholder="Search by waste type, model, or suggestion" />
      <select id="historyWasteFilter" class="role-select">
        <option value="">All waste types</option>
        <% ["Plastic", "Metal", "Paper", "Organic", "Glass", "Unknown"].forEach((type) => { %>
          <option value="<%= type.toLowerCase() %>"><%= type %></option>
        <% }) %>
      </select>
      <button type="button" id="applyHistorySelectionBtn" class="button">Use Selected</button>
    </div>
    <div class="table-wrapper admin-list-modal-body">
      <table class="history-table">
        <thead>
          <tr>
            <th>Select</th>
            <th>Image</th>
            <th>Waste Type</th>
            <th>Model Version</th>
            <th>Confidence</th>
            <th>Suggestion</th>
            <th>Date & Time</th>
          </tr>
        </thead>
        <tbody>
          <% history.forEach((item) => { %>
            <tr
              class="history-modal-row"
              data-search="<%= `${item.wasteType} ${item.modelVersion || ''} ${item.suggestion || ''}`.toLowerCase() %>"
              data-waste="<%= String(item.wasteType || '').toLowerCase() %>"
            >
              <td>
                <input
                  type="checkbox"
                  class="history-select-checkbox"
                  value="<%= item._id %>"
                  data-waste-type="<%= item.wasteType %>"
                  data-image-path="<%= item.imagePath %>"
                />
              </td>
              <td><img src="<%= item.imagePath %>" alt="<%= item.wasteType %>" class="history-thumb" /></td>
              <td><%= item.wasteType %></td>
              <td><%= item.modelVersion || "1.0.0" %></td>
              <td><%= item.confidence ? `${(item.confidence * 100).toFixed(1)}%` : "N/A" %></td>
              <td><%= item.suggestion %></td>
              <td><%= new Date(item.createdAt).toLocaleString() %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</div>

<div id="centersModal" class="centers-modal hidden" aria-hidden="true">
  <div class="centers-modal-backdrop" id="centersModalBackdrop"></div>
  <section class="centers-modal-card" role="dialog" aria-modal="true" aria-labelledby="centersModalTitle">
    <div class="centers-modal-header">
      <div>
        <span class="eyebrow">Collection map</span>
        <h2 id="centersModalTitle">All Center Locations</h2>
        <p class="panel-subtitle">Currently available center: Kuril&ndash;Khilkhet, Dhaka.</p>
      </div>
      <button type="button" id="closeCentersModalBtn" class="modal-close-button" aria-label="Close all centers map">
        &times;
      </button>
    </div>
    <div class="centers-modal-body">
      <div class="modal-map-shell">
        <div id="allCentersMap" class="modal-map-box"></div>
      </div>
      <aside class="modal-center-panel">
        <span class="mini-badge">Active Center</span>
        <h3>Kuril&ndash;Khilkhet Collection Center</h3>
        <p>Dhaka, Bangladesh</p>
        <div class="modal-center-meta">
          <span>Area</span>
          <strong>Kuril&ndash;Khilkhet</strong>
        </div>
        <div class="modal-center-meta">
          <span>Status</span>
          <strong>Available</strong>
        </div>
        <p class="tip-copy">More collection centers can be added later without changing this layout.</p>
      </aside>
    </div>
  </section>
</div>

<script src="https://cdn.jsdelivr.net/npm/@tensorflow/tfjs@4.20.0/dist/tf.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@tensorflow-models/mobilenet@2.1.1/dist/mobilenet.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@teachablemachine/image@0.8/dist/teachablemachine-image.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script
  src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
  crossorigin=""
></script>
<script>
  window.intelliEcoModelConfig = <%- JSON.stringify(modelConfig) %>;
</script>
<script src="/js/dashboard.js"></script>

<%- include("../partials/footer") %>
