<%- include("../partials/head") %>
<%- include("../partials/navbar") %>

<main class="auth-page">
  <%- include("../partials/flash") %>

  <section class="auth-card">
    <h1>Verify Account</h1>
    <p>Enter your email address and the verification code you received after registration.</p>

    <form action="/auth/verify-code" method="POST" class="auth-form">
      <label>
        Email
        <input type="email" name="email" required />
      </label>
      <label>
        Verification Code
        <input type="text" name="verificationCode" maxlength="6" required />
      </label>
      <button type="submit" class="button">Verify Account</button>
    </form>

    <p class="helper-link">Already verified? <a href="/login">Go to login</a></p>
  </section>
</main>

<%- include("../partials/footer") %>
