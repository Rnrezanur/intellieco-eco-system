<nav class="site-nav">
  <a href="/" class="brand">IntelliEco</a>
  <div class="nav-links">
    <a href="/">Home</a>
    <% if (currentUser) { %>
      <% if (currentUser.role === "admin") { %>
        <a href="/admin">Admin</a>
      <% } else { %>
        <a href="/dashboard">Dashboard</a>
      <% } %>
      <a href="/profile" class="user-menu-link" aria-label="Open profile settings">
        <span class="user-avatar">
          <% if (currentUser.profileImage) { %>
            <img src="<%= currentUser.profileImage %>" alt="<%= currentUser.name || "User" %> profile picture" />
          <% } else { %>
            <%= (currentUser.name || currentUser.email || "U").charAt(0).toUpperCase() %>
          <% } %>
        </span>
        <span class="user-menu-name"><%= currentUser.name || "Profile" %></span>
      </a>
      <form action="/auth/logout" method="POST">
        <button type="submit" class="ghost-button">Logout</button>
      </form>
    <% } else { %>
      <a href="/login">Login</a>
      <a href="/register" class="primary-link">Register</a>
    <% } %>
  </div>
</nav>
